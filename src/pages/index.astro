      <div class="flex flex-col items-center text-center">

        <img
          src={avatar.src}
          alt="Juan Alfredo Gutierrez"
          class="w-32 h-32 rounded-full border-4 border-cyan-400 shadow-lg"
        />
          <h1 class="mt-8 text-5xl md:text-6xl font-bold text-cyan-400">
          Juan Alfredo Gutierrez
        </h1>

        <h2 class="mt-4 text-2xl text-slate-300">
          Senior Software Engineer • Software Architect
        </h2>

        <p class="mt-6 max-w-3xl text-lg text-slate-400">
          Building cloud-native platforms, distributed systems,
          microservices and AI-powered solutions using .NET,
          Azure and modern software architecture.
        </p>

        <div class="mt-8 flex gap-4">

          <a
            href="https://github.com/juanalfredogutierrez"
            target="_blank"
            class="px-6 py-3 bg-cyan-500 rounded-lg font-semibold hover:bg-cyan-600"
